PORT=8000
HOST=0.0.0.0
ENV=development
ENVIRONMENT=local
LOG_FILE=app.log

# Database — set DATABASE_URL directly, or use individual Postgres vars
# DATABASE_URL=postgresql+psycopg2://postgres:changethis@localhost:5432/app
DATABASE_URL=sqlite:///expenses.db

# Or use individual Postgres vars (DATABASE_URL takes precedence)
# POSTGRES_SERVER=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=app
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=changethis

# Security
SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Email
SMTP_SERVER=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_SENDER_NAME=Expense Tracker

# Frontend
FRONTEND_URL=http://localhost:3000

# OpenAI (optional — for invoice OCR)
OPENAI_API_KEY=

# Sentry (optional)
SENTRY_DSN=
